# Copy to .env and fill in values

# App
DEBUG=false
APP_NAME=PriceCompare
API_PREFIX=/api/v1

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/pricecompare
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10

# Redis
REDIS_URL=redis://redis:6379/0
CACHE_TTL_SECONDS=300
PRICE_CACHE_TTL_SECONDS=1800

# Celery
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# Crawler
CRAWLER_CONCURRENCY=10
CRAWLER_TIMEOUT_SECONDS=30
CRAWLER_RETRY_ATTEMPTS=3
RATE_LIMIT_DELAY_SECONDS=1.5

# OpenTelemetry
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
OTEL_SERVICE_NAME=pricecompare-api
OTEL_ENVIRONMENT=development

# CORS
ALLOWED_ORIGINS=["http://localhost:3000","http://frontend:3000"]

# Frontend (server-side — used by Next.js rewrites, not exposed to browser)
BACKEND_URL=http://localhost:8000
# Frontend (browser-side)
NEXT_PUBLIC_OTEL_ENDPOINT=http://localhost:4318/v1/traces
